<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="TrackSphere — The world's most powerful real-time location tracking platform. Pin-point GPS accuracy with sub-50ms latency.">
    <meta name="keywords" content="real-time tracker, GPS tracking, live map, location sharing, Socket.io">
    <meta property="og:title" content="TrackSphere — Real-Time Location Intelligence">
    <meta property="og:description" content="Track any device, anywhere in the world with millisecond precision.">
    <title>TrackSphere — Real-Time Location Intelligence</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
    <!-- Particle Canvas Background -->
    <canvas id="particle-canvas"></canvas>

    <!-- ═══════════ NAVBAR ═══════════ -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo">
                <div class="logo-icon">
                    <div class="logo-pulse"></div>
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="20" r="17" stroke="url(#nGrad)" stroke-width="1.5"/>
                        <ellipse cx="20" cy="20" rx="9" ry="17" stroke="url(#nGrad)" stroke-width="1.2" fill="none"/>
                        <line x1="3" y1="20" x2="37" y2="20" stroke="url(#nGrad)" stroke-width="1.2" opacity="0.6"/>
                        <line x1="7" y1="12" x2="33" y2="12" stroke="url(#nGrad)" stroke-width="0.8" opacity="0.4"/>
                        <line x1="7" y1="28" x2="33" y2="28" stroke="url(#nGrad)" stroke-width="0.8" opacity="0.4"/>
                        <circle cx="20" cy="20" r="3" fill="#00f5ff"/>
                        <circle cx="20" cy="20" r="6" stroke="#00f5ff" stroke-width="1" opacity="0.3"/>
                        <defs>
                            <linearGradient id="nGrad" x1="0" y1="0" x2="40" y2="40">
                                <stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <span class="logo-text">Track<span class="logo-accent">Sphere</span></span>
            </a>
            <ul class="nav-links" id="navLinks">
                <li><a href="#features" class="nav-link">Features</a></li>
                <li><a href="#stats" class="nav-link">Performance</a></li>
                <li><a href="#how-it-works" class="nav-link">How It Works</a></li>
            </ul>
            <a href="/tracker" class="nav-cta" id="navCta">
                <span>Launch Tracker</span>
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12M10 4l6 6-6 6"/></svg>
            </a>
            <button class="hamburger" id="hamburger" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- ═══════════ HERO ═══════════ -->
    <section class="hero" id="hero">
        <div class="hero-grid-bg"></div>

        <div class="hero-inner">
            <!-- Left: Text -->
            <div class="hero-text">
                <div class="hero-badge">
                    <span class="badge-dot"></span>
                    <span>Live Tracking Active</span>
                    <span class="badge-users" id="heroUserCount">0 online</span>
                </div>

                <h1 class="hero-title">
                    The World's Most Powerful<br>
                    <span class="gradient-text">Real&#8209;Time</span> Location Tracker
                </h1>

                <p class="hero-subtitle">
                    Pin-point GPS accuracy. Sub-50ms latency. Zero setup required.
                    Track any device, anywhere on the planet — in real time.
                </p>

                <div class="hero-cta-group">
                    <a href="/tracker" class="btn-primary" id="heroCta">
                        <span class="btn-shine"></span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5" fill="white" stroke="none"/></svg>
                        Launch Tracker Free
                    </a>
                    <a href="#features" class="btn-ghost">
                        Explore Features
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                    </a>
                </div>

                <div class="hero-proof">
                    <div class="proof-item">
                        <strong class="hero-counter" data-target="10847">0</strong>
                        <span>Active Users</span>
                    </div>
                    <div class="proof-sep"></div>
                    <div class="proof-item">
                        <strong class="hero-counter" data-target="156" data-suffix="+">0</strong>
                        <span>Countries</span>
                    </div>
                    <div class="proof-sep"></div>
                    <div class="proof-item">
                        <strong class="hero-counter" data-target="12" data-suffix="ms">0</strong>
                        <span>Avg Latency</span>
                    </div>
                </div>
            </div>

            <!-- Right: Globe -->
            <div class="hero-visual">
                <div class="globe-scene">
                    <!-- Outer ambient rings -->
                    <div class="ambient-ring ar-1"></div>
                    <div class="ambient-ring ar-2"></div>
                    <div class="ambient-ring ar-3"></div>

                    <!-- Orbit satellites -->
                    <div class="orbit-track ot-1"><div class="satellite sat-1"></div></div>
                    <div class="orbit-track ot-2"><div class="satellite sat-2"></div></div>

                    <!-- Globe body -->
                    <div class="globe-body">
                        <div class="globe-sphere">
                            <!-- Latitude lines -->
                            <div class="lat lat-1"></div>
                            <div class="lat lat-2"></div>
                            <div class="lat lat-eq"></div>
                            <div class="lat lat-3"></div>
                            <div class="lat lat-4"></div>
                            <!-- Meridian wrapper that rotates -->
                            <div class="meridians">
                                <div class="mer mer-0"></div>
                                <div class="mer mer-1"></div>
                                <div class="mer mer-2"></div>
                                <div class="mer mer-3"></div>
                            </div>
                            <!-- Location pins -->
                            <div class="globe-pin gp-1"><div class="gp-ring"></div></div>
                            <div class="globe-pin gp-2"><div class="gp-ring"></div></div>
                            <div class="globe-pin gp-3"><div class="gp-ring"></div></div>
                            <div class="globe-pin gp-4 gp-active"><div class="gp-ring"></div></div>
                            <!-- Continent patches -->
                            <div class="continent c-na"></div>
                            <div class="continent c-eu"></div>
                            <div class="continent c-as"></div>
                            <!-- Shine -->
                            <div class="globe-shine"></div>
                        </div>
                        <div class="globe-glow-floor"></div>
                    </div>

                    <!-- Floating info cards -->
                    <div class="float-card fc-tl">
                        <div class="fc-dot"></div>
                        <div>
                            <div class="fc-title">New York, US</div>
                            <div class="fc-sub">Just connected · 3s ago</div>
                        </div>
                    </div>
                    <div class="float-card fc-br">
                        <div class="fc-dot fc-dot-purple"></div>
                        <div>
                            <div class="fc-title">⚡ 12ms latency</div>
                            <div class="fc-sub">Real-time sync active</div>
                        </div>
                    </div>
                    <div class="float-card fc-bl">
                        <div class="fc-dot fc-dot-green"></div>
                        <div>
                            <div class="fc-title">3 Users Tracking</div>
                            <div class="fc-sub">Live on map now</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="scroll-cue">
            <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
            <span>Scroll to explore</span>
        </div>
    </section>

    <!-- ═══════════ FEATURES ═══════════ -->
    <section class="features" id="features">
        <div class="section-wrap">
            <div class="section-head reveal">
                <span class="eyebrow">Core Capabilities</span>
                <h2>Built for <span class="gradient-text">Precision</span></h2>
                <p>Everything you need for world-class real-time tracking, out of the box.</p>
            </div>

            <div class="features-grid">
                <article class="feat-card reveal" data-delay="0">
                    <div class="feat-icon-wrap" data-color="cyan">
                        <svg viewBox="0 0 48 48" fill="none">
                            <circle cx="24" cy="24" r="20" stroke="url(#fg1)" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.5"/>
                            <circle cx="24" cy="24" r="12" stroke="url(#fg1)" stroke-width="1.5"/>
                            <circle cx="24" cy="24" r="4" fill="#00f5ff"/>
                            <path d="M24 4 L24 44 M4 24 L44 24" stroke="url(#fg1)" stroke-width="0.8" opacity="0.3"/>
                            <defs><linearGradient id="fg1" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Sub-50ms Real-Time</h3>
                    <p>WebSocket-powered location streaming with GPS-grade precision. Every movement tracked the instant it happens.</p>
                    <div class="feat-tags">
                        <span>WebSocket</span><span>GPS</span><span>&lt;50ms</span>
                    </div>
                </article>

                <article class="feat-card feat-card-featured reveal" data-delay="100">
                    <div class="feat-badge">⭐ Core Feature</div>
                    <div class="feat-icon-wrap" data-color="purple">
                        <svg viewBox="0 0 48 48" fill="none">
                            <path d="M24 6 L40 16 L40 36 L24 46 L8 36 L8 16 Z" stroke="url(#fg2)" stroke-width="1.5" fill="none"/>
                            <circle cx="24" cy="26" r="6" fill="url(#fg2)"/>
                            <circle cx="15" cy="18" r="3" stroke="url(#fg2)" stroke-width="1.2" fill="none"/>
                            <circle cx="33" cy="18" r="3" stroke="url(#fg2)" stroke-width="1.2" fill="none"/>
                            <path d="M18 18 L21 22 M30 18 L27 22" stroke="url(#fg2)" stroke-width="1" opacity="0.7"/>
                            <defs><linearGradient id="fg2" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Unlimited Multi-User</h3>
                    <p>Track unlimited devices simultaneously. Each user appears as a live marker, updating in real-time as they move.</p>
                    <div class="feat-tags">
                        <span>Unlimited</span><span>Live Markers</span><span>Auto-clean</span>
                    </div>
                </article>

                <article class="feat-card reveal" data-delay="200">
                    <div class="feat-icon-wrap" data-color="cyan">
                        <svg viewBox="0 0 48 48" fill="none">
                            <circle cx="24" cy="24" r="20" stroke="url(#fg3)" stroke-width="1.5"/>
                            <ellipse cx="24" cy="24" rx="10" ry="20" stroke="url(#fg3)" stroke-width="1" fill="none"/>
                            <path d="M4 24 Q14 18 24 24 Q34 30 44 24" stroke="url(#fg3)" stroke-width="1" fill="none" opacity="0.6"/>
                            <path d="M4 24 Q14 30 24 24 Q34 18 44 24" stroke="url(#fg3)" stroke-width="0.8" fill="none" opacity="0.3"/>
                            <circle cx="24" cy="24" r="3.5" fill="#7c3aed"/>
                            <defs><linearGradient id="fg3" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Global Coverage</h3>
                    <p>OpenStreetMap tiles cover every inch of the planet. Works from Antarctica to the Arctic Circle.</p>
                    <div class="feat-tags">
                        <span>OpenStreetMap</span><span>Worldwide</span>
                    </div>
                </article>

                <article class="feat-card reveal" data-delay="300">
                    <div class="feat-icon-wrap" data-color="purple">
                        <svg viewBox="0 0 48 48" fill="none">
                            <rect x="10" y="18" width="28" height="22" rx="3" stroke="url(#fg4)" stroke-width="1.5"/>
                            <path d="M18 18 L18 14 Q18 8 24 8 Q30 8 30 14 L30 18" stroke="url(#fg4)" stroke-width="1.5" fill="none"/>
                            <circle cx="24" cy="29" r="4" stroke="url(#fg4)" stroke-width="1.5"/>
                            <path d="M24 33 L24 36" stroke="url(#fg4)" stroke-width="1.5" stroke-linecap="round"/>
                            <defs><linearGradient id="fg4" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Zero Data Storage</h3>
                    <p>Location data streams only between live clients. Nothing is logged, stored, or persisted — ever. GDPR-friendly by design.</p>
                    <div class="feat-tags">
                        <span>No Storage</span><span>GDPR</span><span>Private</span>
                    </div>
                </article>

                <article class="feat-card reveal" data-delay="400">
                    <div class="feat-icon-wrap" data-color="cyan">
                        <svg viewBox="0 0 48 48" fill="none">
                            <path d="M24 8 L38 16 L38 32 L24 40 L10 32 L10 16 Z" stroke="url(#fg5)" stroke-width="1.5" fill="none"/>
                            <circle cx="24" cy="24" r="5" fill="url(#fg5)"/>
                            <path d="M24 8 L24 19 M24 29 L24 40 M10 16 L19 21 M29 27 L38 32 M38 16 L29 21 M19 27 L10 32" stroke="url(#fg5)" stroke-width="0.8" opacity="0.5"/>
                            <defs><linearGradient id="fg5" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Instant, No Sign-Up</h3>
                    <p>Open the link and you're live in under a second. No account, no config, no friction. Share the URL to invite anyone.</p>
                    <div class="feat-tags">
                        <span>Zero Setup</span><span>Share URL</span><span>Instant</span>
                    </div>
                </article>

                <article class="feat-card reveal" data-delay="500">
                    <div class="feat-icon-wrap" data-color="purple">
                        <svg viewBox="0 0 48 48" fill="none">
                            <rect x="8" y="10" width="32" height="22" rx="3" stroke="url(#fg6)" stroke-width="1.5"/>
                            <path d="M20 32 L18 40 M28 32 L30 40 M16 40 L32 40" stroke="url(#fg6)" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M15 18 L20 23 L28 15" stroke="#00f5ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <defs><linearGradient id="fg6" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <h3>Works on Any Device</h3>
                    <p>Fully responsive from 4K monitors to mobile phones. The map adapts fluidly to any screen size or orientation.</p>
                    <div class="feat-tags">
                        <span>Mobile-First</span><span>Responsive</span><span>Cross-Platform</span>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- ═══════════ STATS ═══════════ -->
    <section class="stats-section" id="stats">
        <div class="stats-glow-l"></div>
        <div class="stats-glow-r"></div>
        <div class="section-wrap">
            <div class="stats-grid reveal">
                <div class="stat-tile">
                    <div class="stat-icon">🌍</div>
                    <div class="stat-val counter" data-target="10847" data-suffix="+">0+</div>
                    <div class="stat-name">Active Users Worldwide</div>
                    <div class="stat-track"><div class="stat-fill" style="--pct:85%"></div></div>
                </div>
                <div class="stat-tile">
                    <div class="stat-icon">🗺️</div>
                    <div class="stat-val counter" data-target="156">0</div>
                    <div class="stat-name">Countries Covered</div>
                    <div class="stat-track"><div class="stat-fill" style="--pct:78%"></div></div>
                </div>
                <div class="stat-tile">
                    <div class="stat-icon">⚡</div>
                    <div class="stat-val"><span class="counter" data-target="12">0</span>ms</div>
                    <div class="stat-name">Average Latency</div>
                    <div class="stat-track"><div class="stat-fill" style="--pct:98%"></div></div>
                </div>
                <div class="stat-tile">
                    <div class="stat-icon">✅</div>
                    <div class="stat-val"><span class="counter" data-target="99">0</span>.9%</div>
                    <div class="stat-name">Uptime Reliability</div>
                    <div class="stat-track"><div class="stat-fill" style="--pct:99%"></div></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ HOW IT WORKS ═══════════ -->
    <section class="hiw" id="how-it-works">
        <div class="section-wrap">
            <div class="section-head reveal">
                <span class="eyebrow">Simple as 1-2-3</span>
                <h2>How It <span class="gradient-text">Works</span></h2>
                <p>From zero to live tracking in under 10 seconds. No setup, no expertise required.</p>
            </div>

            <div class="hiw-steps">
                <div class="hiw-step reveal" data-delay="0">
                    <div class="hiw-num">01</div>
                    <div class="hiw-card">
                        <div class="hiw-icon">
                            <svg viewBox="0 0 40 40" fill="none">
                                <rect x="8" y="4" width="24" height="32" rx="3" stroke="currentColor" stroke-width="1.5"/>
                                <circle cx="20" cy="31" r="1.5" fill="currentColor"/>
                                <path d="M13 11 L27 11 M13 16 L27 16 M13 21 L22 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <h3>Open the App</h3>
                        <p>Navigate to the Tracker page on any device. Works instantly in Chrome, Firefox, Safari, or any modern browser — no installation needed.</p>
                    </div>
                </div>

                <div class="hiw-arrow reveal" data-delay="100">→</div>

                <div class="hiw-step reveal" data-delay="200">
                    <div class="hiw-num">02</div>
                    <div class="hiw-card">
                        <div class="hiw-icon">
                            <svg viewBox="0 0 40 40" fill="none">
                                <path d="M20 4C13.37 4 8 9.37 8 16c0 9 12 20 12 20s12-11 12-20c0-6.63-5.37-12-12-12z" stroke="currentColor" stroke-width="1.5"/>
                                <circle cx="20" cy="16" r="4" fill="currentColor"/>
                            </svg>
                        </div>
                        <h3>Allow Location</h3>
                        <p>Grant your browser permission to read GPS coordinates. Your location streams live via WebSocket — nothing is ever stored on our servers.</p>
                    </div>
                </div>

                <div class="hiw-arrow reveal" data-delay="300">→</div>

                <div class="hiw-step reveal" data-delay="400">
                    <div class="hiw-num">03</div>
                    <div class="hiw-card">
                        <div class="hiw-icon">
                            <svg viewBox="0 0 40 40" fill="none">
                                <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M10 20 Q15 12 20 20 Q25 28 30 20" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                <path d="M20 10 Q28 15 20 20 Q12 25 20 30" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                <circle cx="27" cy="13" r="2.5" fill="#00f5ff"/>
                                <circle cx="27" cy="13" r="5" stroke="#00f5ff" stroke-width="1" opacity="0.4"/>
                            </svg>
                        </div>
                        <h3>Track Live</h3>
                        <p>See all connected users appear on the globe-mapped Leaflet map in real-time. Share the URL to invite others into your live session.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ CTA ═══════════ -->
    <section class="cta-section" id="cta">
        <div class="cta-orb cta-orb-l"></div>
        <div class="cta-orb cta-orb-r"></div>
        <div class="section-wrap">
            <div class="cta-box reveal">
                <div class="cta-glow-top"></div>
                <span class="eyebrow">Get Started Now</span>
                <h2 class="cta-title">Ready to Track the <span class="gradient-text">World?</span></h2>
                <p class="cta-sub">Join thousands of users already experiencing real-time location intelligence. Free, instant, no sign-up.</p>
                <a href="/tracker" class="btn-primary btn-xl" id="ctaLaunch">
                    <span class="btn-shine"></span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5" fill="white" stroke="none"/></svg>
                    Launch Tracker — It's Free
                </a>
                <div class="cta-checks">
                    <span>✓ No sign-up</span>
                    <span>✓ Works on mobile</span>
                    <span>✓ Zero latency</span>
                    <span>✓ Open source</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ FOOTER ═══════════ -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <a href="/" class="nav-logo">
                    <div class="logo-icon small">
                        <svg viewBox="0 0 40 40" fill="none">
                            <circle cx="20" cy="20" r="17" stroke="url(#fGrad)" stroke-width="1.5"/>
                            <ellipse cx="20" cy="20" rx="9" ry="17" stroke="url(#fGrad)" stroke-width="1.2" fill="none"/>
                            <line x1="3" y1="20" x2="37" y2="20" stroke="url(#fGrad)" stroke-width="1.2" opacity="0.6"/>
                            <circle cx="20" cy="20" r="3" fill="#00f5ff"/>
                            <defs><linearGradient id="fGrad" x1="0" y1="0" x2="40" y2="40"><stop stop-color="#00f5ff"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
                        </svg>
                    </div>
                    <span class="logo-text">Track<span class="logo-accent">Sphere</span></span>
                </a>
                <p>Real-time location intelligence for the modern world. Open-source, private, instant.</p>
            </div>
            <div class="footer-nav">
                <div class="footer-col">
                    <h4>Product</h4>
                    <a href="#features">Features</a>
                    <a href="#how-it-works">How It Works</a>
                    <a href="/tracker">Live Tracker</a>
                </div>
                <div class="footer-col">
                    <h4>Built With</h4>
                    <a href="https://nodejs.org" target="_blank" rel="noopener noreferrer">Node.js</a>
                    <a href="https://socket.io" target="_blank" rel="noopener noreferrer">Socket.io</a>
                    <a href="https://leafletjs.com" target="_blank" rel="noopener noreferrer">Leaflet.js</a>
                    <a href="https://expressjs.com" target="_blank" rel="noopener noreferrer">Express</a>
                </div>
            </div>
        </div>
        <div class="footer-bar">
            <p>© 2026 TrackSphere — Built with ❤️ using Node.js, Socket.io & Leaflet</p>
            <p class="footer-status"><span class="live-dot"></span>All systems operational</p>
        </div>
    </footer>

    <script src="/js/landing.js"></script>
</body>
</html>
